<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^home2/localins/public_html/?$ / [L,R=301]
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^home2/localins/public_html/(.+?)/?$ /$1.html [L,R=301]
  RewriteRule ^home2/localins/public_html/(.*)$ /$1 [L,R=301]

  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), payment=(), usb=(), geolocation=()"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self'; form-action 'self' https://wa.me; upgrade-insecure-requests"
</IfModule>
